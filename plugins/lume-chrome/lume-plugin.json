{
  "schema": "lume-plugin/v1",
  "name": "lume-chrome",
  "version": "0.5.1",
  "description": "Provide an authenticated external Chrome backend for Lume Browser.",
  "author": "CavinHuang",
  "displayName": "Lume Browse",
  "category": "Browser",
  "marketplace": {
    "icon": "./assets/logo.png",
    "thumbnail": "./assets/thumbnail.svg",
    "docs": "./README.md",
    "setup": [
      {
        "id": "install-extension",
        "title": "安装 Chrome 扩展",
        "description": "在 Chrome 扩展页加载或安装插件包内的 MV3 扩展,确保扩展处于启用状态。",
        "kind": "install",
        "artifact": { "path": "./lume-browser-extension-v6.zip", "kind": "chrome-extension" },
        "targetApp": {
          "kind": "chrome",
          "installHint": "chrome://extensions → 加载已解压的扩展程序"
        },
        "verify": {
          "method": "chrome-extension",
          "detail": "hgoclajdgiicjpnggdkjidkopoleddoe"
        }
      },
      {
        "id": "install-native-host",
        "title": "安装 Native Host",
        "description": "点击安装后,Lume 会选择当前平台的预编译 Native Host，完成校验、注册并将当前用户配对密钥写入系统凭证库。无需 Rust、npm 或命令行。",
        "kind": "install",
        "artifacts": [
          { "path": "./runtime/win32-x64/lume-chrome-host.exe", "kind": "native-binary", "platform": "win32", "arch": "x64" },
          { "path": "./runtime/darwin-x64/lume-chrome-host", "kind": "native-binary", "platform": "darwin", "arch": "x64" },
          { "path": "./runtime/darwin-arm64/lume-chrome-host", "kind": "native-binary", "platform": "darwin", "arch": "arm64" },
          { "path": "./runtime/linux-x64/lume-chrome-host", "kind": "native-binary", "platform": "linux", "arch": "x64" }
        ],
        "installer": {
          "kind": "chrome-native-host",
          "hostName": "com.lume.browser",
          "extensionId": "hgoclajdgiicjpnggdkjidkopoleddoe",
          "appServerUrl": "ws://127.0.0.1:43127/browser"
        },
        "targetApp": {
          "kind": "system-path",
          "installHint": "由 Lume 安装到当前用户目录并注册到 Chrome"
        }
      },
      {
        "id": "keep-chrome-ready",
        "title": "保持 Chrome 与 Lume 运行",
        "description": "安装后重启 Lume，再打开 Chrome；Lume 会读取当前用户的 bridge 配置，扩展弹窗应显示 Native Host 已连接。",
        "kind": "local-service"
      },
      {
        "id": "confirm-browser-auth",
        "title": "确认浏览器授权",
        "description": "从插件详情页试用会以 $lume-chrome 激活技能；受控高风险操作由 Lume Broker 确认，密码、剪贴板、上传和 Agent 下载不向外部 Chrome 后端开放。",
        "kind": "browser-auth"
      }
    ]
  },
  "skills": ["./skills/"],
  "permissions": {
    "filesystem": {
      "read": ["./**"]
    },
    "tools": {
      "allow": ["mcp__node_repl__js"]
    },
    "network": {
      "outbound": []
    },
    "shell": {
      "allow": false
    }
  }
}
